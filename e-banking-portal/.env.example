# ============================================================
# Heritage Vault — E-Banking Portal
# Environment Variables
# ============================================================
# Copy this file to .env.local for local development.
# On Render: set these in Dashboard → Environment → Environment Variables.
# IMPORTANT: NEXT_PUBLIC_* vars are baked into the client bundle at
# build time. They must be set BEFORE the build runs, not just at runtime.
# ============================================================

# ------------------------------------------------------------
# REQUIRED
# ------------------------------------------------------------

# Backend Core API public URL.
# Local dev:  http://localhost:3001
# Render:     https://heritage-core-api.onrender.com  (your Render backend URL)
# Production: https://api.jpheritagebank.com
NEXT_PUBLIC_API_URL=https://your-backend-api.onrender.com

# Corporate website URL. Used for "Back to site" links and signup redirects.
# Local dev:  http://localhost:3002
# Netlify:    https://jpheritagebank.netlify.app  (your Netlify URL)
# Production: https://jpheritagebank.com
NEXT_PUBLIC_CORPORATE_URL=https://your-corporate-site.netlify.app

# ------------------------------------------------------------
# OPTIONAL
# ------------------------------------------------------------

# OCR provider for invoice scanning feature.
# Leave blank — /api/bills/upload-invoice returns 422 and the UI
# falls back to manual entry until a real OCR service is integrated.
# Future values: "aws-textract" | "google-vision"
NEXT_PUBLIC_OCR_PROVIDER=

# Disable Next.js telemetry (recommended for production)
NEXT_TELEMETRY_DISABLED=1

# Node environment — set automatically by Render
NODE_ENV=production

# Port — Render sets this automatically. Only needed for Docker / self-hosted.
PORT=4000
