                className="w-full h-10 rounded-sm border border-gray-300 bg-white px-3 text-sm text-gray-900 focus:outline-none focus:border-[color:var(--heritage-navy)] focus:ring-2 focus:ring-[color:var(--heritage-navy)]/30"
                value={fromAccount?.id ?? ""}
                onChange={e => setFromAccountId(e.target.value)}
              >
                <option value="">Select account</option>
                {mockAccounts.map(acc => (
                  <option key={acc.id} value={acc.id}>
                    {acc.name} ({acc.number}) · {acc.currency} {acc.balance.toLocaleString()}
                  </option>
                ))}
              </select>
              {fromAccount && (
                <p className="text-xs text-gray-500">
                  Available balance: {fromAccount.currency} {fromAccount.balance.toLocaleString()}
                </p>
              )}
            </div>

            <div className="space-y-2">
              <label className="text-xs font-medium text-gray-700">Amount</label>
              <div className="flex rounded-sm border border-gray-300 bg-white focus-within:border-[color:var(--heritage-navy)] focus-within:ring-2 focus-within:ring-[color:var(--heritage-navy)]/30">
                <input
                  className="flex-1 h-10 px-3 text-sm text-gray-900 bg-transparent outline-none"
                  inputMode="decimal"
                  placeholder="0.00"
                  value={amount}
                  onChange={e => setAmount(e.target.value)}
                />
                <div className="flex items-center px-3 text-xs text-gray-600 border-l border-gray-200">
                  USD
                </div>
              </div>
              {limitExceeded ? (
                <p className="text-xs text-red-600">
                  This exceeds your daily limit. Reduce the amount.
                </p>
              ) : (
                <p className="text-xs text-gray-500">
                  Remaining after this transfer: USD {Math.max(remainingAfter, 0).toLocaleString()}
                </p>
              )}
            </div>
          </div>

          <div className="space-y-2">
            <label className="text-xs font-medium text-gray-700">Recipient</label>
            <select
              className="w-full h-10 rounded-sm border border-gray-300 bg-white px-3 text-sm text-gray-900 focus:outline-none focus:border-[color:var(--heritage-navy)] focus:ring-2 focus:ring-[color:var(--heritage-navy)]/30"
              value={recipientId}
              onChange={e => setRecipientId(e.target.value)}
            >
              <option value="">Select saved recipient</option>
              {mockRecipients.map(r => (
                <option key={r.id} value={r.id}>
                  {r.name} ({r.account}) · {r.bank}
                </option>
              ))}
            </select>
            <button
              type="button"
              className="text-xs text-[color:var(--heritage-navy)] hover:text-[color:var(--heritage-navy-mid)]"
            >
              Add new recipient
            </button>
          </div>

          <div className="space-y-2">
            <label className="text-xs font-medium text-gray-700">Reference for your statement</label>
            <input
              className="w-full h-10 rounded-sm border border-gray-300 bg-white px-3 text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:border-[color:var(--heritage-navy)] focus:ring-2 focus:ring-[color:var(--heritage-navy)]/30"
              placeholder="e.g. Rent payment"
            />
            <p className="text-xs text-gray-500">Shown on your statement and, where supported, the recipient’s.</p>
          </div>

          <div className="pt-2">
            <button
              type="button"
              disabled={reviewDisabled || limitExceeded}
              onClick={() => setIsReview(true)}
              className={[
                "w-full h-11 inline-flex items-center justify-center text-sm font-medium rounded-sm transition",
                reviewDisabled || limitExceeded
                  ? "bg-gray-300 text-gray-500 cursor-not-allowed"
                  : "bg-[color:var(--heritage-navy)] text-white hover:bg-[color:var(--heritage-navy-mid)]",
              ].join(" ")}
            >
              Next: Review details
            </button>
          </div>
        </div>
      )}

      {isReview && (
        <div className="space-y-4">
          <h3 className="text-sm font-medium text-gray-800">Review transfer</h3>
          <div className="rounded-sm border border-[color:var(--heritage-navy)]/10 bg-white/80 p-4 space-y-2 text-sm text-gray-700">
            <div className="flex justify-between">
              <span>From</span>
              <span>{fromAccount ? `${fromAccount.name} (${fromAccount.number})` : "Not selected"}</span>
            </div>
            <div className="flex justify-between">
              <span>To</span>
              <span>
                {recipientId
                  ? mockRecipients.find(r => r.id === recipientId)?.name
                  : "Not selected"}
              </span>
            </div>
            <div className="flex justify-between">
              <span>Amount</span>
              <span>USD {amount || "0.00"}</span>
            </div>
            <div className="flex justify-between text-xs text-gray-500 pt-1">
              <span>Estimated fee</span>
              <span>USD 0.00</span>
            </div>
          </div>
          <div className="flex items-center justify-between gap-3 pt-2">
            <button
              type="button"
              className="text-xs text-[color:var(--heritage-navy)] hover:text-[color:var(--heritage-navy-mid)]"
              onClick={() => setIsReview(false)}
            >
              Back to edit
            </button>
            <button
              type="button"
              className="h-11 px-6 inline-flex items-center justify-center text-sm font-medium rounded-sm bg-[color:var(--heritage-navy)] text-white hover:bg-[color:var(--heritage-navy-mid)]"
            >
              Confirm transfer
            </button>
          </div>
        </div>
      )}
    </div>
  );
}

type LimitsPanelProps = {
  dailyLimit: number;
  usedToday: number;
  amount: number;
};

function LimitsPanel({ dailyLimit, usedToday, amount }: LimitsPanelProps) {
  const totalUsed = usedToday + amount;
  const ratio = Math.min(totalUsed / dailyLimit, 1);
  const remaining = Math.max(dailyLimit - totalUsed, 0);

  return (
    <div className="bg-[color:var(--heritage-surface)]/95 backdrop-blur-md border border-[color:var(--heritage-navy)]/10 shadow-md rounded-sm p-4 space-y-3">
      <h3 className="text-sm font-medium text-[color:var(--heritage-navy)]">
        Transfer limits
      </h3>
      <div className="space-y-1 text-xs text-gray-700">
        <div className="flex justify-between">
          <span>Daily limit</span>
          <span>USD {dailyLimit.toLocaleString()}</span>
        </div>
        <div className="flex justify-between">
          <span>Used today</span>
          <span>USD {totalUsed.toLocaleString()}</span>
        </div>
        <div className="flex justify-between">
          <span>Remaining after this transfer</span>
          <span>USD {remaining.toLocaleString()}</span>
        </div>
      </div>
      <div className="h-1.5 w-full rounded-full bg-gray-200 overflow-hidden">
        <div
          className="h-full rounded-full bg-[color:var(--heritage-navy)] transition-[width]"
          style={{ width: `${ratio * 100}%` }}
        />
      </div>
      <p className="text-xs text-gray-500">
        Large transfers may require additional verification.
      </p>
    </div>
  );
}

function SecurityPanel() {
  return (
    <div className="bg-[color:var(--heritage-surface)]/95 backdrop-blur-md border border-[color:var(--heritage-navy)]/10 shadow-md rounded-sm p-4 space-y-2">
      <h3 className="text-sm font-medium text-[color:var(--heritage-navy)]">
        Security & processing
      </h3>
      <ul className="space-y-1 text-xs text-gray-700">
        <li>Transfers are encrypted end-to-end.</li>
        <li>Internal transfers post instantly.</li>
        <li>External transfers may take 1–3 business days.</li>
        <li>Unusual activity may require a quick verification call.</li>
      </ul>
    </div>
  );
}
