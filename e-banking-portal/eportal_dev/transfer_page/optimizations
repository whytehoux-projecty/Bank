### FEATURE 4: Multi-Step Transfer Flow with Progress Indicator

#### Implementation Strategy
**Action**: Wrap existing form in a stepper component  
**Preservation**: Keep all existing form fields, just reorganize into steps

#### Component Structure
```tsx
// WRAPPER COMPONENT - Add around existing transfer form
import React, { useState } from 'react';

type TransferStep = 'details' | 'review' | 'verify' | 'confirm';

interface StepConfig {
  id: TransferStep;
  label: string;
  icon: string;
  description: string;
}

const TRANSFER_STEPS: StepConfig[] = [
  {
    id: 'details',
    label: 'Transfer Details',
    icon: 'FileText',
    description: 'Enter transfer information'
  },
  {
    id: 'review',
    label: 'Review',
    icon: 'Eye',
    description: 'Verify transfer details'
  },
  {
    id: 'verify',
    label: 'Verify',
    icon: 'Shield',
    description: 'Security verification'
  },
  {
    id: 'confirm',
    label: 'Complete',
    icon: 'CheckCircle',
    description: 'Transfer confirmation'
  }
];

export const TransferStepper: React.FC<{
  children: React.ReactNode;
}> = ({ children }) => {
  const [currentStep, setCurrentStep] = useState<TransferStep>('details');
  const [completedSteps, setCompletedSteps] = useState<TransferStep[]>([]);
  const [transferData, setTransferData] = useState<any>(null);

  const currentStepIndex = TRANSFER_STEPS.findIndex(s => s.id === currentStep);

  const handleNext = (data: any) => {
    setTransferData({ ...transferData, ...data });
    setCompletedSteps([...completedSteps, currentStep]);
    
    const nextIndex = currentStepIndex + 1;
    if (nextIndex < TRANSFER_STEPS.length) {
      setCurrentStep(TRANSFER_STEPS[nextIndex].id);
    }
  };

  const handleBack = () => {
    const prevIndex = currentStepIndex - 1;
    if (prevIndex >= 0) {
      setCurrentStep(TRANSFER_STEPS[prevIndex].id);
    }
  };

  const isStepCompleted = (stepId: TransferStep) => {
    return completedSteps.includes(stepId);
  };

  const isStepActive = (stepId: TransferStep) => {
    return currentStep === stepId;
  };

  return (
    <div className="transfer-stepper">
      {/* Progress Indicator */}
      <div className="stepper-progress">
        {TRANSFER_STEPS.map((step, index) => (
          <div 
            key={step.id}
            className={`step-item ${isStepActive(step.id) ? 'active' : ''} ${isStepCompleted(step.id) ? 'completed' : ''}`}
          >
            {/* Step Number/Icon */}
            <div className="step-indicator">
              {isStepCompleted(step.id) ? (
                <CheckIcon size={20} />
              ) : (
                <span className="step-number">{index + 1}</span>
              )}
            </div>

            {/* Step Info */}
            <div className="step-info">
              <div className="step-label">{step.label}</div>
              <div className="step-description">{step.description}</div>
            </div>

            {/* Connector Line */}
            {index < TRANSFER_STEPS.length - 1 && (
              <div className={`step-connector ${isStepCompleted(step.id) ? 'completed' : ''}`} />
            )}
          </div>
        ))}
      </div>

      {/* Step Content */}
      <div className="stepper-content">
        {currentStep === 'details' && (
          <StepDetails 
            onNext={handleNext}
            initialData={transferData}
          />
        )}

        {currentStep === 'review' && (
          <StepReview 
            data={transferData}
            onNext={handleNext}
            onBack={handleBack}
          />
        )}

        {currentStep === 'verify' && (
          <StepVerify 
            data={transferData}
            onNext={handleNext}
            onBack={handleBack}
          />
        )}

        {currentStep === 'confirm' && (
          <StepConfirm 
            data={transferData}
          />
        )}
      </div>
    </div>
  );
};

// STEP 1: Details (Your existing form goes here)
const StepDetails: React.FC<{
  onNext: (data: any) => void;
  initialData: any;
}> = ({ onNext, initialData }) => {
  const [formData, setFormData] = useState(initialData || {});

  const handleSubmit = (e: React.FormEvent) => {
    e.preventDefault();
    onNext(formData);
  };

  return (
    <form onSubmit={handleSubmit} className="step-form">
      {/* 
        YOUR EXISTING FORM FIELDS GO HERE
        - Transfer Type Selector
        - Account Selector (From)
        - Beneficiary Selector / Recipient Input
        - Amount Input
        - Reference/Description
      */}
      
      <div className="form-actions">
        <button type="submit" className="btn btn-primary btn-full">
          Review Transfer
          <ArrowRightIcon size={20} />
        </button>
      </div>
    </form>
