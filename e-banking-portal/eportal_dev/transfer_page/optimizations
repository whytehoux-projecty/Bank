### Example API Implementation

```typescript
// Example: Beneficiary Controller
import { Request, Response } from 'express';

export class BeneficiaryController {
  // GET /api/beneficiaries
  async list(req: Request, res: Response) {
    const { userId } = req.user;
    const { type } = req.query;

    try {
      let query = db('beneficiaries')
        .where({ user_id: userId })
        .orderBy('last_used_at', 'desc');

      if (type) {
        query = query.where({ beneficiary_type: type });
      }

      const beneficiaries = await query;
      
      res.json({
        success: true,
        data: beneficiaries,
        count: beneficiaries.length
      });
    } catch (error) {
      res.status(500).json({
        success: false,
        error: 'Failed to fetch beneficiaries'
      });
    }
  }

  // POST /api/beneficiaries
  async create(req: Request, res: Response) {
    const { userId } = req.user;
    const beneficiaryData = req.body;

    try {
      // Validate beneficiary data
      const validationErrors = validateBeneficiary(beneficiaryData);
      if (validationErrors.length > 0) {
        return res.status(400).json({
          success: false,
          errors: validationErrors
        });
      }

      // Check for duplicates
      const existing = await db('beneficiaries')
        .where({
          user_id: userId,
          account_number: beneficiaryData.accountNumber
        })
        .first();

      if (existing) {
        return res.status(409).json({
          success: false,
          error: 'Beneficiary already exists'
        });
      }

      // Create beneficiary
      const [beneficiary] = await db('beneficiaries')
        .insert({
          user_id: userId,
          ...beneficiaryData,
          created_at: new Date(),
          updated_at: new Date()
        })
        .returning('*');

      // For external beneficiaries, initiate verification
      if (beneficiaryData.beneficiary_type === 'external') {
        await initiateMicroDepositVerification(beneficiary.id);
      }

      res.status(201).json({
        success: true,
        data: beneficiary
      });
    } catch (error) {
      res.status(500).json({
        success: false,
        error: 'Failed to create beneficiary'
      });
    }
  }

  // POST /api/beneficiaries/:id/verify
  async verify(req: Request, res: Response) {
    const { userId } = req.user;
    const { id } = req.params;
    const { amount1, amount2 } = req.body;

    try {
      // Verify micro-deposit amounts
      const isValid = await verifyMicroDeposits(id, amount1, amount2);

      if (isValid) {
        await db('beneficiaries')
          .where({ id, user_id: userId })
          .update({
            is_verified: true,
            updated_at: new Date()
          });

        res.json({
          success: true,
          message: 'Beneficiary verified successfully'
        });
      } else {
        res.status(400).json({
          success: false,
          error: 'Verification failed. Incorrect amounts.'
        });
      }
    } catch (error) {
      res.status(500).json({
        success: false,
        error: 'Verification failed'
      });
    }
  }
}

// Helper function
function validateBeneficiary(data: any): string[] {
  const errors: string[] = [];

  if (!data.name) errors.push('Name is required');
  if (!data.accountNumber) errors.push('Account number is required');
  
  if (data.beneficiary_type === 'external' && !data.routingNumber) {
    errors.push('Routing number required for external accounts');
  }

  if (data.beneficiary_type === 'international') {
    if (!data.swift_code && !data.iban) {
      errors.push('SWIFT code or IBAN required for international transfers');
    }
  }

  return errors;
}
