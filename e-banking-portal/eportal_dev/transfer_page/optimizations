    transfer_type VARCHAR(50) NOT NULL,
    from_account_id UUID REFERENCES accounts(id),
    beneficiary_id UUID REFERENCES beneficiaries(id),
    amount DECIMAL(15, 2),
    reference VARCHAR(255),
    is_recurring BOOLEAN DEFAULT FALSE,
    frequency VARCHAR(20), -- 'daily', 'weekly', 'monthly', 'yearly'
    next_execution_date DATE,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Scheduled Transfers Table
CREATE TABLE scheduled_transfers (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id UUID NOT NULL REFERENCES users(id) ON DELETE CASCADE,
    from_account_id UUID NOT NULL REFERENCES accounts(id),
    beneficiary_id UUID REFERENCES beneficiaries(id),
    amount DECIMAL(15, 2) NOT NULL,
    transfer_type VARCHAR(50) NOT NULL,
    scheduled_date DATE NOT NULL,
    status VARCHAR(20) DEFAULT 'pending' CHECK (status IN ('pending', 'processing', 'completed', 'failed', 'cancelled')),
    reference VARCHAR(255),
    is_recurring BOOLEAN DEFAULT FALSE,
    frequency VARCHAR(20),
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    executed_at TIMESTAMP,
    CONSTRAINT future_date CHECK (scheduled_date >= CURRENT_DATE)
);

-- Transfer Verification Table
CREATE TABLE transfer_verifications (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    transfer_id UUID REFERENCES transfers(id) ON DELETE CASCADE,
    verification_method VARCHAR(20) CHECK (verification_method IN ('sms', 'email', 'app', 'biometric')),
    verification_code VARCHAR(10),
    code_sent_at TIMESTAMP,
    code_expires_at TIMESTAMP,
    verified_at TIMESTAMP,
    attempts INT DEFAULT 0,
    is_verified BOOLEAN DEFAULT FALSE,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

