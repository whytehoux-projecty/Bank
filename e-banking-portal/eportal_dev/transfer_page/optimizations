```tsx
// ENHANCED - Replace with this interactive selector
import React, { useState, useEffect } from 'react';

interface Account {
  id: string;
  accountNumber: string;
  accountType: 'checking' | 'savings' | 'money_market' | 'credit';
  balance: number;
  availableBalance: number;
  accountName: string;
  currency: string;
  isDefault?: boolean;
}

export const AccountSelector: React.FC<{
  label: string;
  value: string;
  onChange: (account: Account) => void;
  excludeAccount?: string; // For "To Account" to exclude "From Account"
  transferAmount?: number; // To validate sufficient funds
}> = ({ label, value, onChange, excludeAccount, transferAmount }) => {
  const [accounts, setAccounts] = useState<Account[]>([]);
  const [isOpen, setIsOpen] = useState(false);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState<string | null>(null);
  const [selectedAccount, setSelectedAccount] = useState<Account | null>(null);

  useEffect(() => {
    fetchAccounts();
  }, []);

  const fetchAccounts = async () => {
    setLoading(true);
    setError(null);
    
    try {
      const response = await fetch('/api/accounts');
      
      if (!response.ok) {
        throw new Error('Failed to load accounts');
      }
      
      const data = await response.json();
      setAccounts(data);
      
      // Auto-select default account
      const defaultAccount = data.find((acc: Account) => acc.isDefault);
      if (defaultAccount && !value) {
        setSelectedAccount(defaultAccount);
        onChange(defaultAccount);
      }
    } catch (err) {
      setError(err.message);
    } finally {
      setLoading(false);
    }
  };

  const handleRetry = () => {
    fetchAccounts();
  };

  const handleSelect = (account: Account) => {
    setSelectedAccount(account);
    onChange(account);
    setIsOpen(false);
  };

  const getAccountIcon = (type: string) => {
    switch (type) {
      case 'checking': return '💳';
      case 'savings': return '🏦';
      case 'money_market': return '📈';
      case 'credit': return '💎';
      default: return '💰';
    }
  };

  const hasInsufficientFunds = (account: Account) => {
    return transferAmount && account.availableBalance < transferAmount;
  };

  const filteredAccounts = accounts.filter(
    acc => acc.id !== excludeAccount
  );

  // Loading State
  if (loading) {
    return (
      <div className="account-selector loading">
        <label>{label}</label>
        <div className="skeleton-loader">
          <div className="skeleton-line"></div>
          <div className="skeleton-line short"></div>
        </div>
      </div>
    );
  }

  // Error State
  if (error) {
    return (
      <div className="account-selector error-state">
        <label>{label}</label>
        <div className="error-banner">
          <AlertCircleIcon size={20} />
          <div className="error-content">
            <p className="error-message">{error}</p>
            <button 
              className="btn-retry"
              onClick={handleRetry}
            >
              Try Again
            </button>
          </div>
        </div>
      </div>
    );
  }

  return (
    <div className="account-selector">
      <label>{label}</label>
      
      {/* Selected Account Display */}
      <div 
        className={`account-display ${isOpen ? 'open' : ''}`}
        onClick={() => setIsOpen(!isOpen)}
      >
        {selectedAccount ? (
          <div className="selected-account">
            <div className="account-icon">
              {getAccountIcon(selectedAccount.accountType)}
            </div>
            <div className="account-info">
              <div className="account-name">
                {selectedAccount.accountName}
              </div>
              <div className="account-number">
                {maskAccountNumber(selectedAccount.accountNumber)}
              </div>
            </div>
            <div className="account-balance">
              <div className="balance-label">Available</div>
              <div className="balance-amount">
                ${formatNumber(selectedAccount.availableBalance)}
              </div>
            </div>
            <ChevronDownIcon 
              size={20} 
              className={`chevron ${isOpen ? 'rotated' : ''}`}
            />
          </div>
        ) : (
          <div className="placeholder">
            Select account
            <ChevronDownIcon size={20} />
          </div>
        )}
      </div>

      {/* Dropdown Options */}
      {isOpen && (
        <div className="account-dropdown">
          {filteredAccounts.map((account) => {
            const insufficient = hasInsufficientFunds(account);
            
            return (
              <button
                key={account.id}
                className={`account-option ${insufficient ? 'insufficient' : ''} ${selectedAccount?.id === account.id ? 'selected' : ''}`}
                onClick={() => !insufficient && handleSelect(account)}
                disabled={insufficient}
              >
                <div className="account-icon">
                  {getAccountIcon(account.accountType)}
                </div>
                <div className="account-info">
                  <div className="account-name">
                    {account.accountName}
                    {account.isDefault && (
                      <span className="default-badge">DEFAULT</span>
                    )}
                  </div>
                  <div className="account-number">
                    {maskAccountNumber(account.accountNumber)}
                  </div>
                </div>
                <div className="account-balance">
                  <div className="balance-label">Available</div>
                  <div className={`balance-amount ${insufficient ? 'insufficient' : ''}`}>
                    ${formatNumber(account.availableBalance)}
                  </div>
                  {insufficient && (
                    <div className="insufficient-label">
                      Insufficient funds
                    </div>
                  )}
                </div>
                {selectedAccount?.id === account.id && (
                  <CheckIcon size={20} color="#10B981" />
                )}
              </button>
            );
          })}
        </div>
      )}

      {/* Balance Warning */}
      {selectedAccount && transferAmount && (
        <div className="balance-warning">
          {hasInsufficientFunds(selectedAccount) ? (
            <div className="warning error">
              <AlertCircleIcon size={16} />
              Insufficient funds. Available: ${formatNumber(selectedAccount.availableBalance)}
            </div>
          ) : selectedAccount.availableBalance - transferAmount < 100 ? (
            <div className="warning caution">
              <AlertTriangleIcon size={16} />
              Low balance after transfer: ${formatNumber(selectedAccount.availableBalance - transferAmount)}
            </div>
          ) : (
            <div className="balance-preview">
              New balance: ${formatNumber(selectedAccount.availableBalance - transferAmount)}
            </div>
          )}
        </div>
      )}
    </div>
  );
};

// Helper functions
const maskAccountNumber = (accountNumber: string) => {
  return '****' + accountNumber.slice(-4);
};

const formatNumber = (num: number) => {
  return num.toLocaleString('en-US', {
    minimumFractionDigits: 2,
    maximumFractionDigits: 2
  });
};
