# ============================================================
# JP Heritage Bank — Admin Interface
# Environment Variables
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# --- SERVER ---
NODE_ENV=production
PORT=3003
HOST=0.0.0.0
LOG_LEVEL=info

# --- DATABASE ---
# Same PostgreSQL instance as the Core API (shared schema).
# Render internal URL (same-region services):
#   postgresql://user:pass@dpg-xxxx-a:5432/jp_heritage_postgres
# Render external URL (for local testing):
#   postgresql://user:pass@dpg-xxxx-a.oregon-postgres.render.com:5432/jp_heritage_postgres
DATABASE_URL="postgresql://jp_heritage_postgres_user:PASSWORD@HOST:5432/jp_heritage_postgres"

# --- REDIS ---
# Same Redis instance as the Core API.
# Render internal URL: redis://red-xxxx:6379
REDIS_URL="redis://red-xxxx:6379"

# --- JWT & COOKIE SECRETS ---
# Generate with: openssl rand -base64 32
# JWT_SECRET here is for ADMIN tokens only — must be different from core-api's JWT_SECRET.
JWT_SECRET="your-admin-jwt-secret-minimum-32-chars"
JWT_EXPIRES_IN="24h"
COOKIE_SECRET="your-cookie-secret-minimum-32-chars"

# --- ADMIN SESSION ---
ADMIN_SESSION_TIMEOUT=86400000
BCRYPT_ROUNDS=12

# --- CORS ---
# Only the admin domain should be allowed here.
CORS_ORIGIN="https://admin.jpheritagebank.com"

# --- RATE LIMITING ---
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=900000

# --- FILE UPLOADS ---
MAX_FILE_SIZE=10485760
UPLOAD_DIR="./uploads"

# --- BACKEND CORE API CONNECTION ---
# Admin proxies portal-status operations through to the Core API.
# Use the public Render URL since Render services are not on the same
# internal network unless using Docker Compose.
API_URL="https://heritage-core-api.onrender.com"

# --- OPTIONAL: EMAIL (SMTP) ---
# If not set, notifications are logged to console only.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# --- OPTIONAL: WEBHOOKS ---
STAFF_PORTAL_API_URL=""
WEBHOOK_SECRET=""

# --- SECURITY ---
HELMET_CSP_ENABLED=true
ENABLE_REQUEST_LOGGING=true
ENABLE_ERROR_TRACKING=true

# --- DEVELOPMENT ONLY (set false in production) ---
ENABLE_SWAGGER_DOCS=false
ENABLE_DEBUG_ROUTES=false
